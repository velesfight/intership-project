{
  "name": "nude_web_v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "npx swagger-typescript-api generate --path https://dev-back-nude-sdhf43sd5f-v2.ghfls.ru/docs-yaml --output src/shared/api/artifacts --name generated.ts --responses --sort-types --sort-routes --axios --unwrap-response-data",
    "build:prod": "vite build",
    "build:staging": "vite build --mode staging",
    "dev": "vite",
    "format": "prettier --list-different .",
    "format:fix": "prettier --list-different --write .",
    "lint": "eslint *.js *.ts src --report-unused-disable-directives",
    "lint:fix": "npm run lint -- --fix",
    "lint:inspect": "npx @eslint/config-inspector",
    "optimize:svg": "svgo public src/shared/assets --recursive",
    "prepare": "husky",
    "preview": "vite preview",
    "storybook": "storybook dev --port 5201 --no-open",
    "stylelint": "stylelint --ignore-path .gitignore \"**/*.css\" --allow-empty-input",
    "stylelint:fix": "npm run stylelint -- --fix strict",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/geologica": "^5.2.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@csstools/postcss-global-data": "^3.0.0",
    "@eslint/js": "^9.27.0",
    "@storybook/react-vite": "^9.0.15",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^3.10.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.1",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^4.13.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.0.15",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "postcss-preset-env": "^10.2.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.14",
    "storybook": "^9.0.15",
    "stylelint": "^16.20.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-use-logical-spec": "^5.0.1",
    "svgo": "^3.3.2",
    "swagger-typescript-api": "^13.1.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.0",
    "typescript-plugin-css-modules": "^5.1.0",
    "validate-branch-name": "^1.3.2",
    "vite": "^6.3.5",
    "vite-plugin-mkcert": "^1.17.8",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
